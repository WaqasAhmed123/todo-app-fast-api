# Copy this file to .env and replace the placeholder values with your own.
DATABASE_URL="mssql+pyodbc:///?odbc_connect=DRIVER%3D%7BODBC+Driver+18+for+SQL+Server%7D%3BSERVER%3D<YOUR_SERVER_NAME>%3BDATABASE%3Dtodo_app_python%3BUID%3D<YOUR_DB_USER>%3BPWD%3D<YOUR_DB_PASSWORD>%3BTrustServerCertificate%3Dyes%3B"
SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
